{% raw %}set shell := ["bash", "-cu"]

# First-time setup: install deps, create DB, run migrations, seed data
setup:
    @echo "==> Installing dependencies..."
    python -m venv apps/backend/.venv
    apps/backend/.venv/bin/pip install -e "apps/backend/.[dev]"
    pnpm install
    @echo "==> Setting up database..."
    docker compose up -d db
    @echo "==> Waiting for PostgreSQL to be ready..."
    sleep 3
    @echo "==> Running migrations..."
    cd apps/backend && .venv/bin/alembic upgrade head
    @echo "==> Seeding database with admin user and sample data..."
    cd apps/backend && .venv/bin/python -m app.seed
    @echo "✓ Setup complete! Run 'just dev' to start development servers."

# Install all dependencies (run once after cloning)
install:
    python -m venv apps/backend/.venv
    apps/backend/.venv/bin/pip install -e "apps/backend/.[dev]"
    pnpm install
    pnpm --filter "*-client" generate

# Development
dev:
    docker compose up -d db
    cd apps/backend && .venv/bin/uvicorn app.main:app --reload --port 8000 &
    cd apps/frontend && pnpm dev

# Build
build:
    cd apps/frontend && pnpm build

# Lint
lint:
    cd apps/backend && .venv/bin/ruff check . && .venv/bin/ruff format --check .
    cd apps/frontend && pnpm lint

# Format
format:
    cd apps/backend && .venv/bin/ruff format .
    cd apps/frontend && pnpm lint --fix

# Test
test:
    docker compose up -d db
    @sleep 2
    docker compose exec -T db psql -U app -c "CREATE DATABASE app_test;" 2>/dev/null || true
    cd apps/backend && DATABASE_URL="postgresql+asyncpg://app:app@localhost:54325/app_test" .venv/bin/pytest
    cd apps/frontend && pnpm test --run

# Test with coverage report
test-cov:
    docker compose up -d db
    @sleep 2
    docker compose exec -T db psql -U app -c "CREATE DATABASE app_test;" 2>/dev/null || true
    cd apps/backend && DATABASE_URL="postgresql+asyncpg://app:app@localhost:54325/app_test" .venv/bin/pytest --cov=app --cov-report=term-missing --cov-report=html
    cd apps/frontend && pnpm test --run
    @echo "HTML report: apps/backend/htmlcov/index.html"

# Generate OpenAPI client types
generate-client:
    cd packages/client && pnpm generate

# Database
db-migrate message:
    cd apps/backend && .venv/bin/alembic revision --autogenerate -m "{{message}}"

db-upgrade:
    cd apps/backend && .venv/bin/alembic upgrade head

db-downgrade:
    cd apps/backend && .venv/bin/alembic downgrade -1

# Seed database with admin user and sample data
seed:
    cd apps/backend && .venv/bin/python -m app.seed

# Reset database: wipe data, recreate tables, seed admin user
reset:
    @echo "==> Stopping and removing database volume..."
    docker compose down -v
    @echo "==> Starting fresh database..."
    docker compose up -d db
    @echo "==> Waiting for PostgreSQL to be ready..."
    sleep 3
    @echo "==> Running migrations..."
    just db-upgrade
    @echo "==> Seeding database..."
    just seed
    @echo "✓ Database reset complete. Admin user: admin@example.com / admin"

# FORGE: Plan a new change — the configured agent reads architecture + constraints and produces a full spec
# Usage:
#   just forge-plan <change-id> "<short description>"
#   just forge-plan <change-id> "<short description>" --agent codex
#   just forge-plan <change-id> --from-file <path/to/spec.md>
forge-plan *args:
    python forge/forge_plan.py {{args}}

# FORGE: Review the current plan — print spec.md and tasks.md for the active REVIEW change
forge-review *change_id:
    #!/usr/bin/env bash
    dir="forge/changes/{{change_id}}"
    if [ -z "{{change_id}}" ]; then
        dir=$(python3 -c "import json,pathlib; hits=[str(d) for d in sorted(pathlib.Path('forge/changes').iterdir()) if (d/'state.json').exists() and json.loads((d/'state.json').read_text()).get('phase','')==('REVIEW')]; print(hits[0] if hits else '')" 2>/dev/null)
    fi
    if [ -z "$dir" ] || [ ! -d "$dir" ]; then
        echo "No change in REVIEW phase found. Run 'just forge-plan' first."
        exit 1
    fi
    echo ""
    echo "════════════════════════════════════════════════════════════"
    echo "  SPEC: $dir/spec.md"
    echo "════════════════════════════════════════════════════════════"
    cat "$dir/spec.md"
    echo ""
    echo "════════════════════════════════════════════════════════════"
    echo "  TASKS: $dir/tasks.md"
    echo "════════════════════════════════════════════════════════════"
    cat "$dir/tasks.md"

# FORGE: Approve the current plan — transitions REVIEW → EXECUTE and sets first task
forge-approve *change_id:
    #!/usr/bin/env bash
    if [ -n "{{change_id}}" ]; then
        python forge/forge_approve.py --change {{change_id}}
    else
        python forge/forge_approve.py
    fi

# FORGE: Run autonomous execution loop
# Usage:
#   just forge
#   just forge --agent codex
forge *args:
    python forge/forge_run.py {{args}}

# FORGE: Show current state without executing
forge-status *args:
    python forge/forge_run.py --dry-run {{args}}


# Generate or update Obsidian vault from FORGE documents
vault output_path=".forge-vault" *args:
    python forge/scripts/generate_vault.py --output {{output_path}} {{args}}

# Sync this project with the Copier template safely.
# Refuses to run with uncommitted tracked changes. Disables destructive cleanup
# on failure. Excludes local-only dirs so they survive even if Copier misbehaves.
template-sync *args:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! git diff --quiet HEAD; then
        echo "❌ Working tree not clean. Commit or stash tracked changes first."
        exit 1
    fi
    copier update --trust --cleanup-on-failure=false \
        --exclude='_input/**' --exclude='.claude/**' {{args}}

# Publish local forge/* edits back to the copier template, then bump _commit.
# Without file args: mirrors forge/ → <template>/template/forge/ (refuses if any
#   drifting file contains Jinja markup in the template — those always diverge
#   between project (rendered) and template (with {% raw %}), so full mirror
#   would clobber them).
# With file args: cherry-publish only the listed files (paths relative to forge/).
#   Each file is checked individually for Jinja markup on the template side.
# Refuses to clobber uncommitted template-side work either way.
# Usage:
#   just forge-publish "feat(forge): full mirror message"
#   just forge-publish "feat(forge): partial" AGENTS.md PLAN_PROMPT.md forge_run.py
forge-publish msg *files:
    #!/usr/bin/env bash
    set -euo pipefail

    TEMPLATE=$(sed -n 's/^_src_path: //p' .copier-answers.yml)
    if [ -z "$TEMPLATE" ] || [ ! -d "$TEMPLATE" ]; then
        echo "❌ Could not resolve template path from .copier-answers.yml (_src_path)."
        exit 1
    fi
    DEST="$TEMPLATE/template/forge"
    if [ ! -d "$DEST" ]; then
        echo "❌ Template forge dir missing: $DEST"
        exit 1
    fi

    if ! git -C "$TEMPLATE" diff --quiet HEAD -- template/forge/; then
        echo "❌ Template repo has uncommitted changes in template/forge/."
        echo "   Commit or stash them in $TEMPLATE before publishing."
        exit 1
    fi

    FILES="{{files}}"
    JINJA_RE='\{%-?\s*(raw|if|for|set|endraw|endif|endfor)|\{\{'

    if [ -z "$FILES" ]; then
        # ── Full mirror path ─────────────────────────────────────────
        RSYNC_EXCLUDES=(--exclude='changes/' --exclude='__pycache__/' --exclude='logs/' --exclude='*.pyc')
        DRIFT=$(rsync -rnc --out-format='%n' "${RSYNC_EXCLUDES[@]}" forge/ "$DEST/" | grep -v '/$' || true)
        BLOCKED=()
        for f in $DRIFT; do
            tpl_path="$DEST/$f"
            if [ -f "$tpl_path" ] && grep -qE "$JINJA_RE" "$tpl_path"; then
                BLOCKED+=("$f")
            fi
        done
        if [ ${#BLOCKED[@]} -gt 0 ]; then
            echo "❌ Refusing to clobber template files with Jinja markup:"
            for f in "${BLOCKED[@]}"; do echo "     template/forge/$f"; done
            echo ""
            echo "   These render to a different shape in the project. Either:"
            echo "     1) Cherry-publish only the safe files:"
            echo "        just forge-publish \"<msg>\" <relpath1> <relpath2> ..."
            echo "     2) Edit them upstream in the template and 'just template-sync' to pull."
            exit 1
        fi

        echo "==> Mirroring forge/ → $DEST/"
        rsync -av --delete "${RSYNC_EXCLUDES[@]}" forge/ "$DEST/"
    else
        # ── Cherry-publish path (per-file) ───────────────────────────
        # Validate each listed file BEFORE touching anything in the template.
        for f in $FILES; do
            src="forge/$f"
            dst="$DEST/$f"
            if [ ! -f "$src" ]; then
                echo "❌ Source missing: $src"
                exit 1
            fi
            if [ -f "$dst" ] && grep -qE "$JINJA_RE" "$dst"; then
                echo "❌ template/forge/$f contains Jinja markup; edit upstream instead."
                exit 1
            fi
        done
        echo "==> Cherry-mirroring $(echo $FILES | wc -w) file(s) into $DEST/"
        for f in $FILES; do
            src="forge/$f"
            dst="$DEST/$f"
            mkdir -p "$(dirname "$dst")"
            cp "$src" "$dst"
            echo "    forge/$f → template/forge/$f"
        done
    fi

    if git -C "$TEMPLATE" diff --quiet -- template/forge/ && \
       [ -z "$(git -C "$TEMPLATE" ls-files --others --exclude-standard -- template/forge/)" ]; then
        echo "✓ Nothing to publish — template already matches."
        exit 0
    fi

    echo "==> Committing in template"
    git -C "$TEMPLATE" add template/forge/
    git -C "$TEMPLATE" commit -m "{{msg}}"
    NEW_SHA=$(git -C "$TEMPLATE" rev-parse HEAD)

    echo "==> Bumping _commit in project"
    sed -i "s/^_commit: .*/_commit: $NEW_SHA/" .copier-answers.yml
    git add .copier-answers.yml
    git commit -m "chore: bump copier _commit to ${NEW_SHA:0:7}"

    echo ""
    echo "✓ Published. Template HEAD: ${NEW_SHA:0:7}"
